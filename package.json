{
  "name": "jsproxy",
  "version": "1.0.0",
  "description": "A resilient HTTP/HTTPS proxy server with WebSocket support and automatic SSL certificate generation",
  "main": "index.js",
  "bin": {"jsproxy": "index.js"},
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "dev:80": "HTTP_PORT=80 HTTPS_PORT=443 ENABLE_HTTPS=false npm run dev",
    "dev:443": "HTTP_PORT=80 HTTPS_PORT=443 ENABLE_HTTPS=true npm run dev",
    "dev:custom": "HTTP_PORT=3000 HTTPS_PORT=3443 ENABLE_HTTPS=false npm run dev",
    "start:prod": "NODE_ENV=production HTTP_PORT=80 HTTPS_PORT=443 ENABLE_HTTPS=true npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:dev": "docker-compose --profile dev up jsproxy-dev",
    "docker:prod": "docker-compose up jsproxy",
    "docker:tools": "docker-compose --profile tools up",
    "build:linux-x86": "pkg . --target node20-linux-x64 --output dist/jsproxy-linux-x86",
    "build:linux-arm": "pkg . --target node20-linux-arm64 --output dist/jsproxy-linux-arm",
    "build:macosx-arm": "pkg . --target node20-macos-arm64 --output dist/jsproxy-macosx-arm",
    "release:linux-x86": "npm run build:linux-x86 && node scripts/release.js linux-x86",
    "release:linux-arm": "npm run build:linux-arm && node scripts/release.js linux-arm",
    "release:macosx-arm": "npm run build:macosx-arm && node scripts/release.js macosx-arm"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/build/Release/*.node",
      "node_modules/axios/dist/node/*.cjs"
    ],
    "scripts": [],
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-arm64"
    ]
  },
  "keywords": [
    "proxy",
    "https",
    "websocket",
    "ssl",
    "acme",
    "sqlite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "acme-client": "^5.3.0",
    "dotenv": "^17.3.1",
    "http-proxy": "^1.18.1",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "tar": "^7.5.10",
    "@tootallnate/once": "^3.0.1"
  }
}
