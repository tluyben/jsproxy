# JSProxy Configuration

# Environment
NODE_ENV=development

# HTTP Server Configuration
HTTP_PORT=8080
HTTPS_PORT=8443
ENABLE_HTTPS=false
FORCE_HTTPS=false

# Database Configuration (optional overrides)
DB_PATH=./data/current.db

# Certificate Configuration (optional overrides)
# CERTS_DIR=./certs

# Logging Configuration (optional)
# LOG_LEVEL=info

# Raw TCP proxying (optional, opt-in)
# TCP routes are added with scripts/add-tcp-route.js and listen on their own
# dedicated ports. With no TCP routes configured, none of this applies and the
# proxy behaves exactly as a pure HTTP/HTTPS proxy.
# TCP_CONNECT_TIMEOUT_MS=3000   # upstream connect timeout (falls back to HA_CONNECT_TIMEOUT_MS)
# TCP_IDLE_TIMEOUT_MS=0         # idle timeout for established TCP conns; 0 = never (default)

# Webhook Interceptor (optional)
# Fire a POST request for every matched domain before proxying.
# 200 response → proxy as normal
# 3xx response → redirect the client to the Location header
# Any other non-200 → return that status + body directly to the client
# On timeout or network error the request is proxied as normal (fail-open).
# WEBHOOK_URL=https://your-auth-service.example.com/hook
# WEBHOOK_TIMEOUT=5000        # ms to wait for webhook response (default: 5000)
# WEBHOOK_SECRET=your-secret  # if set, adds X-Webhook-Signature: sha256=<hmac> header

# Production Example:
# NODE_ENV=production
# HTTP_PORT=80
# HTTPS_PORT=443
# ENABLE_HTTPS=true

# Custom Development Ports Example:
# HTTP_PORT=3000
# HTTPS_PORT=3443
# ENABLE_HTTPS=false